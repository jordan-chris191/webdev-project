{% extends 'base.html.twig' %}

{% block title %}Order #{{ order.id }}{% endblock %}

{% block admin_content %}
<div class="orders-container">

    {# HEADER #}
    <div class="orders-header">
        <div>
            <h5><i class="fas fa-receipt me-2"></i>Order #{{ order.id }}</h5>
            <p class="text-muted small mb-0">
                {% if not is_granted('ROLE_STAFF') %}
                    Read-only view
                {% else %}
                    Order details and summary
                {% endif %}
            </p>
        </div>
    </div>

    {# ORDER INFO CARD #}
    <div class="custom-card mb-4">
        <div class="card-body">

            <div class="row g-4">

                <div class="col-md-6">
                    <div class="mb-3">
                        <small class="text-muted">Created At</small>
                        <div class="fw-bold">
                            {{ order.createdAt|date('M d, Y h:i A') }}
                        </div>
                    </div>

                    <div>
                        <small class="text-muted">Updated At</small>
                        <div class="fw-bold">
                            {{ order.updatedAt ? order.updatedAt|date('M d, Y h:i A') : '-' }}
                        </div>
                    </div>
                </div>

                <div class="col-md-6 text-md-end">

                    <small class="text-muted">Status</small>
                    <div class="mt-2">

                        {% if order.status == 'pending' %}
                            <span class="status-badge status-pending">
                                <i class="fas fa-clock"></i> Pending
                            </span>

                        {% elseif order.status == 'confirmed' %}
                            <span class="status-badge status-confirmed">
                                <i class="fas fa-check"></i> Confirmed
                            </span>

                        {% elseif order.status == 'shipped' %}
                            <span class="status-badge status-shipped">
                                <i class="fas fa-truck"></i> Shipped
                            </span>

                        {% elseif order.status == 'delivered' %}
                            <span class="status-badge status-delivered">
                                <i class="fas fa-check-double"></i> Delivered
                            </span>

                        {% elseif order.status == 'cancelled' %}
                            <span class="status-badge status-cancelled">
                                <i class="fas fa-times"></i> Cancelled
                            </span>

                        {% else %}
                            <span class="status-badge status-default">
                                {{ order.status }}
                            </span>
                        {% endif %}

                    </div>

                    {% if is_granted('ROLE_STAFF') and order.status == 'pending' %}
                        <div class="mt-3">
                            <a href="{{ path('app_orders_edit', {id: order.id}) }}"
                               class="btn btn-create-order btn-sm">
                                <i class="fas fa-edit me-2"></i>Edit Status
                            </a>
                        </div>
                    {% endif %}

                </div>

            </div>

        </div>
    </div>

    {# ITEMS CARD #}
    <div class="custom-card">

        <div class="card-header">
            <h6 class="mb-0"><i class="fas fa-box me-2"></i>Order Items</h6>
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="custom-table mb-0">

                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Price</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>

                    <tbody>
                        {% set total = 0 %}

                        {% for item in order.items %}
                            {% set price = item.price is not null ? item.price : item.product.price %}
                            {% set subtotal = item.quantity * price %}
                            {% set total = total + subtotal %}

                            <tr>
                                <td>{{ item.product.name }}</td>
                                <td>{{ item.quantity }}</td>
                                <td>₱{{ price|number_format(2, '.', ',') }}</td>
                                <td><strong>₱{{ subtotal|number_format(2, '.', ',') }}</strong></td>
                            </tr>

                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No items in this order
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>

                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Total:</th>
                            <th class="order-price">₱{{ total|number_format(2, '.', ',') }}</th>
                        </tr>
                    </tfoot>

                </table>
            </div>

        </div>

    </div>

    {# BACK BUTTON #}
    <div class="mt-4">
        <a href="{{ path('app_orders_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Orders
        </a>
    </div>

</div>
{% endblock %}