{% extends 'base.html.twig' %}

{% block title %}Edit Order{% endblock %}

{% block admin_page_title %}Edit Order #{{ order.id }}{% endblock %}

{% block admin_content %}
<div class="orders-container">

    <div class="orders-header">
        <div>
            <h5><i class="fas fa-edit me-2"></i>Edit Order #{{ order.id }}</h5>
            <p class="text-muted small mb-0">Update order status and review details</p>
        </div>
    </div>

    <div class="row">
        {# LEFT: FORM #}
        <div class="col-md-8">

            <div class="custom-card">
                <div class="card-body">

                    <form method="post" action="{{ path('app_orders_edit', {'id': order.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ order.id) }}">

                        <div class="mb-3">
                            <label class="form-label">Order ID</label>
                            <input type="text" class="form-control" value="{{ order.id }}" readonly>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Created At</label>
                            <input type="text" class="form-control"
                                   value="{{ order.createdAt ? order.createdAt|date('M d, Y h:i A') : '' }}"
                                   readonly>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Updated At</label>
                            <input type="text" class="form-control"
                                   value="{{ order.updatedAt ? order.updatedAt|date('M d, Y h:i A') : '-' }}"
                                   readonly>
                        </div>

                        <div class="mb-3">
                            <label class="form-label"><strong>Status</strong></label>

                            <select name="order[status]" class="form-select" required>
                                <option value="pending" {{ order.status == 'pending' ? 'selected' : '' }}>Pending</option>
                                <option value="confirmed" {{ order.status == 'confirmed' ? 'selected' : '' }}>Confirmed</option>
                                <option value="shipped" {{ order.status == 'shipped' ? 'selected' : '' }}>Shipped</option>
                                <option value="delivered" {{ order.status == 'delivered' ? 'selected' : '' }}>Delivered</option>
                                <option value="cancelled" {{ order.status == 'cancelled' ? 'selected' : '' }}>Cancelled</option>
                            </select>

                            <small class="text-muted">Only status can be updated</small>
                        </div>

                        {% if order.items|length > 0 %}
                        <div class="mb-3">
                            <label class="form-label">Order Items</label>

                            <ul class="items-list">
                                {% set total = 0 %}
                                {% for item in order.items %}
                                    {% set total = total + (item.price * item.quantity) %}
                                    <li>
                                        {{ item.product.name }}
                                        <strong>(×{{ item.quantity }})</strong>
                                    </li>
                                {% endfor %}
                            </ul>

                            <div class="text-end mt-2">
                                <strong>Total:</strong>
                                <span class="order-price">
                                    ₱{{ total|number_format(2, '.', ',') }}
                                </span>
                            </div>
                        </div>
                        {% endif %}

                        <button type="submit" class="btn btn-create-order">
                            <i class="fas fa-save me-2"></i>Update Order
                        </button>

                    </form>

                </div>
            </div>

        </div>

        {# RIGHT: STATUS + DELETE #}
        <div class="col-md-4">

            <div class="custom-card mb-3">
                <div class="card-body text-center">

                    <h6 class="mb-3">Current Status</h6>

                    {% if order.status == 'pending' %}
                        <span class="status-badge status-pending">
                            <i class="fas fa-clock"></i> Pending
                        </span>

                    {% elseif order.status == 'confirmed' %}
                        <span class="status-badge status-confirmed">
                            <i class="fas fa-check"></i> Confirmed
                        </span>

                    {% elseif order.status == 'shipped' %}
                        <span class="status-badge status-shipped">
                            <i class="fas fa-truck"></i> Shipped
                        </span>

                    {% elseif order.status == 'delivered' %}
                        <span class="status-badge status-delivered">
                            <i class="fas fa-check-double"></i> Delivered
                        </span>

                    {% elseif order.status == 'cancelled' %}
                        <span class="status-badge status-cancelled">
                            <i class="fas fa-times"></i> Cancelled
                        </span>

                    {% else %}
                        <span class="status-badge status-default">
                            {{ order.status }}
                        </span>
                    {% endif %}

                </div>
            </div>

            <div class="custom-card border-danger">
                <div class="card-header bg-danger text-white">
                    <h6 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Danger Zone</h6>
                </div>

                <div class="card-body">
                    <p class="text-muted small">
                        Deleting this order is permanent and cannot be undone.
                    </p>

                    {{ include('orders/_delete_form.html.twig') }}
                </div>
            </div>

        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('app_orders_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Orders
        </a>
    </div>

</div>
{% endblock %}